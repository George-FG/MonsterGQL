{
  "name": "monstergql",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "frontend": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:lint": "npm --prefix frontend run lint",
    "frontend:lint:fix": "npm --prefix frontend run lint:fix",
    "frontend:typecheck": "npm --prefix frontend run typecheck",
    "backend": "npm --prefix backend start",
    "backend:build": "npm --prefix backend run build",
    "backend:lint": "npm --prefix backend run lint",
    "backend:lint:fix": "npm --prefix backend run lint:fix",
    "backend:typecheck": "npm --prefix backend run typecheck",
    "lint": "npm run frontend:lint && npm run backend:lint",
    "lint:fix": "npm run frontend:lint:fix && npm run backend:lint:fix",
    "typecheck": "npm run frontend:typecheck && npm run backend:typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "db:start": "docker compose -f localdb/docker-compose.yml up -d",
    "db:stop": "docker compose -f localdb/docker-compose.yml down",
    "install:all": "npm install && npm --prefix frontend install && npm --prefix backend install",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:migrate": "npm --prefix backend run prisma:migrate",
    "seed": "npm --prefix backend run seed",
    "codegen": "npm run prisma:generate && npm --prefix backend run codegen && npm --prefix frontend run codegen",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.5.3"
  }
}
