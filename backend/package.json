{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "dependencies": {
    "@apollo/server": "5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cors": "2.8.6",
    "dotenv": "^17.4.2",
    "express": "5.2.1",
    "graphql": "16.12.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rimraf ./dist && tsc && copyfiles **/*.graphql ./dist",
    "start": "npm run build && node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config ./codegen.yml",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "npm exec -- prisma generate",
    "prisma:migrate": "npm exec -- prisma migrate dev",
    "seed": "tsx scripts/seedDrinks.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typed-document-node": "^6.1.7",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-resolvers": "^5.1.7",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "5.0.6",
    "@types/node": "^22.8.6",
    "@types/pg": "^8.20.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.4"
  }
}
